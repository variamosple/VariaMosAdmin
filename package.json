{
  "name": "variamos_admin",
  "version": "0.1.0",
  "private": true,
  "homepage": "variamos_admin/",
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "TZ=UTC react-scripts test",
    "jest:coverage": "TZ=UTC react-scripts test --coverage --watchAll=false",
    "eject": "react-scripts eject",
    "postinstall": "patch-package",
    "prepare": "husky",
    "check-arch": "dependency-cruiser --config .dependency-cruiser.js src/",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "find-deadcode": "knip"
  },
  "dependencies": {
    "@patternfly/react-core": "^6.0.0",
    "@patternfly/react-log-viewer": "^6.0.0",
    "@variamosple/variamos-components": "^0.0.23",
    "axios": "^1.7.7",
    "bootstrap": "^5.3.3",
    "react": "^18.3.1",
    "react-bootstrap": "^2.10.4",
    "react-bootstrap-icons": "^1.11.4",
    "react-dom": "^18.3.1",
    "react-google-charts": "^5.2.1",
    "react-hook-form": "^7.53.0",
    "react-router-dom": "^6.26.1",
    "react-scripts": "^5.0.1",
    "typescript": "^4.9.5",
    "uuid": "^11.1.1",
    "web-vitals": "^2.1.4"
  },
  "devDependencies": {
    "@babel/plugin-proposal-private-property-in-object": "^7.21.11",
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^19.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^27.5.2",
    "@types/node": "^16.18.107",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "cspell": "^8.8.4",
    "cypress": "^15.17.0",
    "dependency-cruiser": "^17.4.3",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jest": "^25.7.0",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-testing-library": "^5.11.0",
    "husky": "^9.1.7",
    "knip": "^6.24.0",
    "lint-staged": "^16.4.0",
    "msw": "^2.15.0",
    "patch-package": "^8.0.0",
    "prettier": "^3.9.4",
    "undici": "^7.28.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "overrides": {
    "nth-check": "^2.0.1",
    "@tootallnate/once": "^2.0.1",
    "postcss": "^8.4.31",
    "serialize-javascript": "^7.0.5",
    "underscore": "^1.13.8",
    "uuid": "^11.1.1",
    "sockjs": {
      "uuid": "^11.1.1"
    }
  },
  "jest": {
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(@open-draft|rettime|until-async)/).+\\.(js|jsx|mjs|cjs|ts|tsx)$"
    ],
    "collectCoverageFrom": [
      "src/**/*.{js,jsx,ts,tsx}",
      "!src/**/*.d.ts",
      "!src/**/domain/Entity/**",
      "!src/**/index.ts",
      "!src/index.tsx",
      "!src/reportWebVitals.ts",
      "!src/**/types/**",
      "!src/shared/constants.ts",
      "!src/shared/components/About/**",
      "!src/**/*.types.ts"
    ]
  }
}
